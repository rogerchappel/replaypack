{
  "name": "replaypack",
  "version": "0.1.0",
  "description": "Deterministic CLI transcript packs for proof-oriented local smokes.",
  "type": "module",
  "bin": {
    "replaypack": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "examples",
    "docs",
    "schemas",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "transcript",
    "replay",
    "fixtures",
    "jsonl",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/replaypack.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/replaypack/issues"
  },
  "homepage": "https://github.com/rogerchappel/replaypack#readme"
}
